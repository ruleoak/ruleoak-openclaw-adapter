#!/usr/bin/env node
import { readFileSync } from "node:fs";
import { evaluateOpenClawAction, replayEvidenceJsonl, loadOpenClawPolicy } from "../src/index.js";
const [cmd, ...args]=process.argv.slice(2);
function option(name){ const i=args.indexOf(name); return i >= 0 ? args[i+1] : null; }
try {
 if(cmd === "validate-action") { const a=JSON.parse(readFileSync(args[0],"utf8")); console.log(JSON.stringify({ok:Boolean(a.kind), action:a},null,2)); process.exit(a.kind?0:1); }
 if(cmd === "evaluate") { const a=JSON.parse(readFileSync(args[0],"utf8")); const policyPath=option("--policy"); const policy=policyPath ? loadOpenClawPolicy(policyPath) : undefined; console.log(JSON.stringify(evaluateOpenClawAction(a, policy),null,2)); process.exit(0); }
 if(cmd === "replay") { console.log(JSON.stringify(replayEvidenceJsonl(readFileSync(args[0],"utf8")),null,2)); process.exit(0); }
 if(cmd === "demo") { const demo=args[0]||"file-delete"; const kind=demo.includes("mcp")?"mcp.tool_call":"filesystem.delete"; console.log(JSON.stringify(evaluateOpenClawAction({kind,path:"/protected",tool:"dangerous.delete"}),null,2)); process.exit(0); }
 console.error("Usage: ruleoak-openclaw-adapter demo|validate-action|evaluate|replay"); process.exit(2);
} catch(e){ console.error(e.message); process.exit(1);}
